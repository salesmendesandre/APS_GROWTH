quadrantChart
    title Wireless Technologies Comparison
    x-axis "Short Range" --> "Long Range"
    y-axis "Low Bandwidth" --> "High Bandwidth"
    quadrant-1 "Cellular Networks (High Power)"
    quadrant-2 "Local Networks (High Power)"
    quadrant-3 "Personal Networks (Low Power)"
    quadrant-4 "LPWAN (Low Power)"
    Wi-Fi: [0.15, 0.85]
    Bluetooth: [0.1, 0.3]
    Zigbee: [0.2, 0.4]
    4G / 5G: [0.85, 0.9]
    LoRaWAN: [0.85, 0.15]
    Sigfox: [0.95, 0.05]
    NB-IoT: [0.75, 0.25]
