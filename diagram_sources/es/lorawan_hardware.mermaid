flowchart TD
    subgraph "Power Management"
        SP[Solar Panel 24V 6W] -->|DC-DC Step-down| CH[Charge Controller]
        BATT[(LiPo Battery 7200mAh)] <--> CH
        CH --> ESP
    end

    subgraph "Heltec LoRa32 (ESP32)"
        ESP[ESP32 SoC]
        OLED[OLED Display]
        LoRa[SX1276 LoRa Chip]
        ESP --- OLED
        ESP --- LoRa
    end

    subgraph "Sensors"
        L[BH1750 Light]
        H[Capacitive Soil Moisture]
        T[Temperature]
    end

    L -- "I2C (SDA, SCL)" --> ESP
    H -- "Analog (ADC)" --> ESP
    T -- "OneWire" --> ESP
    LoRa -- "SPI" --> Ant((Antenna))
